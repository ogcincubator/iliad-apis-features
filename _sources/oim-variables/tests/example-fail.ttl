@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix indo: <https://id3.seadots.eu/indicator/obs/> .
@prefix ind: <https://id3.seadots.eu/indicator/> .
@prefix ses: <http://seadots.eu/ses#> .

# Invalid observed property missing skos:prefLabel and skos:inScheme
indo:invalid-property a sosa:observedProperty .

# Invalid edge missing weight
ses:edge-fail a ses:Edge ;
    ses:from indo:invalid-property ;
    ses:to indo:rainfall-anomaly .
