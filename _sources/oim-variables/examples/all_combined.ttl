ind:indicators-scheme a skos:ConceptScheme ;
    skos:prefLabel "SEADOTS Indicator Scheme"@en ;
    skos:definition "A concept scheme for SEADOTS indicator concepts and observed properties."@en ;
    skos:hasTopConcept indo:sst-degrees-c-germany ,
                       indo:sst-degrees-c-sweden ,
                       indo:average-wind-speed-at-hub-height-150-m-extreme-wind-events-norway ,
                       indo:salinity-germany ,
                       indo:temporal-dimension-sweden ,
                       indo:significant-wave-height-wave-direction-variability-norway ,
                       indo:chlorophyll-germany ,
                       indo:mussel-growth-germany ,
                       indo:sea-surface-temperature-norway ,
                       indo:currents-germany ,
                       indo:salinity-gradients-norway ,
                       indo:nutrients-germany ,
                       indo:north-atlantic-oscillation-nao-and-arctic-amplification-may--norway ,
                       indo:permanent-residents-time-norway ,
                       indo:euros-sweden ,
                       indo:euros-sweden-2 ,
                       indo:gis-map-sweden ,
                       indo:number-generation-capacity-status-sweden ,
                       indo:tonnes-per-50km2-sweden ,
                       indo:tonnes-per-50km2-sweden-2 ,
                       indo:gis-data-coordinates-sweden ,
                       indo:number-of-wind-turbines-norway ,
                       indo:turbine-height-m-norway ,
                       indo:spatial-configuration-of-wind-farm-norway ,
                       indo:coordinates-small-and-or-large-scale-sweden ,
                       indo:kwh-germany ,
                       indo:tonnes-sweden ,
                       indo:tonnes-sweden-2 ,
                       indo:tonnes-germany ,
                       indo:tonnes-germany-2 ,
                       indo:sst-biomass-sweden ,
                       indo:nautical-miles-from-coast-sweden ,
                       indo:tonnes-sweden-3 ,
                       indo:tonnes-sweden-4 ,
                       indo:index-sweden ,
                       indo:rate-sweden ,
                       indo:change-in-rate-sweden ,
                       indo:change-in-rate-sweden-2 ,
                       indo:income-sek-sweden ,
                       indo:tonnes-km2-over-time-sweden ,
                       indo:john-arild-arno-fagne-no-norway ,
                       indo:-sweden ,
                       indo:fuel-price-distance-sweden ,
                       indo:price-tonnes-price-kwh-sweden ,
                       indo:initial-weights-from-fcm-workshop-norway ,
                       indo:updating-seadots-app-norway ,
                       indo:tonnes-km2-sweden .


indo:sst-degrees-c-germany a sosa:ObservableProperty, skos:Concept ;
    rdfs:label "SST (degrees C)" ;
    skos:prefLabel "SST (degrees C)"@en ;
    skos:inScheme ind:indicators-scheme ;
    ses:sesCategory "ECO1: Climate patterns"@en ;
    ses:sesVariable "Climate changes to North Sea hydrology"@en ;
    ses:country "Germany"@en ;
    dcterms:source "Output from the numerical model"@en .

