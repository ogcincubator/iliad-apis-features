{
  "@context": {
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "dct": "http://purl.org/dc/terms/",
    "qudt": "http://qudt.org/schema/qudt/",
    "prov": "http://www.w3.org/ns/prov#",
    "sdo": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "nerc": "http://vocab.nerc.ac.uk/collection/",
    "fmsdi": "https://w3id.org/iliad/fmsdi/",
    "iliad": "https://w3id.org/iliad/property/",

    "shorelineType": {
      "@id": "fmsdi:shorelineType"
    },

    "waterLevelAtCapture": {
      "@id": "fmsdi:waterLevelAtCapture"
    },

    "value": {
      "@id": "qudt:value"
    },

    "unit": {
      "@id": "qudt:unit"
    },

    "verticalDatum": {
      "@id": "fmsdi:verticalDatum"
    },

    "datumName": {
      "@id": "rdfs:label"
    },

    "datumEpoch": {
      "@id": "fmsdi:datumEpoch"
    },

    "crsIdentifier": {
      "@id": "dct:conformsTo",
      "@type": "@id"
    },

    "separationSurface": {
      "@id": "fmsdi:separationSurface"
    },

    "transformationMethod": {
      "@id": "prov:wasGeneratedBy"
    },

    "verticalOrientation": {
      "@id": "fmsdi:verticalOrientation"
    },

    "verticalAccuracy": {
      "@id": "http://vocab.nerc.ac.uk/collection/P01/current/UNCEJJ01/"
    },

    "tidalDatumReference": {
      "@id": "http://vocab.nerc.ac.uk/collection/P02/current/TGRD/"
    },

    "captureMethod": {
      "@id": "http://vocab.nerc.ac.uk/collection/L05/current/"
    },

    "sensorPlatform": {
      "@id": "http://vocab.nerc.ac.uk/collection/L06/current/"
    },

    "ndwiThreshold": {
      "@id": "sdo:propertyValue"
    },

    "tideGaugeRef": {
      "@id": "http://vocab.nerc.ac.uk/collection/S13/current/",
      "@type": "@id"
    },

    "waterLevelModelRef": {
      "@id": "fmsdi:waterLevelModelRef",
      "@type": "@id"
    },

    "temporalValidity": {
      "@id": "fmsdi:temporalValidity"
    },

    "captureDateTime": {
      "@id": "dct:created",
      "@type": "xsd:dateTime"
    },

    "tidalPeriodFraction": {
      "@id": "fmsdi:tidalPeriodFraction"
    },

    "shorelineUncertainty": {
      "@id": "fmsdi:shorelineUncertainty"
    },

    "horizontalUncertainty": {
      "@id": "fmsdi:horizontalUncertainty"
    },

    "waterLevelUncertainty": {
      "@id": "http://vocab.nerc.ac.uk/collection/P01/current/UNCEJJ01/"
    },

    "ihoAccuracyZone": {
      "@id": "fmsdi:ihoAccuracyZone"
    },

    "featureDomain": {
      "@id": "fmsdi:featureDomain"
    },

    "dataLineage": {
      "@id": "prov:wasDerivedFrom"
    },

    "sourceDataset": {
      "@id": "prov:wasDerivedFrom",
      "@type": "@id"
    },

    "captureDate": {
      "@id": "dct:created",
      "@type": "xsd:dateTime"
    },

    "gapFilled": {
      "@id": "fmsdi:gapFilled",
      "@type": "xsd:boolean"
    },

    "interpolationMethod": {
      "@id": "fmsdi:interpolationMethod"
    },

    "confidenceLevel": {
      "@id": "fmsdi:confidenceLevel"
    }
  }
}
