{
  "@context": {
    "dwc": "http://rs.tdwg.org/dwc/terms/",
    "dct": "http://purl.org/dc/terms/",
    "sosa": "http://www.w3.org/ns/sosa/",
    "schema": "https://schema.org/",
    "nerc": "http://vocab.nerc.ac.uk/collection/",
    "obis": "https://obis.org/",
    "worms": "https://www.marinespecies.org/aphia.php?p=taxdetails&id=",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "occurrenceID":    { "@id": "dwc:occurrenceID" },
    "basisOfRecord":   { "@id": "dwc:basisOfRecord" },
    "catalogNumber":   { "@id": "dwc:catalogNumber" },
    "collectionCode":  { "@id": "dwc:collectionCode" },
    "institutionCode": { "@id": "dwc:institutionCode" },
    "datasetID":       { "@id": "dwc:datasetID" },
    "occurrenceStatus":{ "@id": "dwc:occurrenceStatus" },

    "scientificName":     { "@id": "dwc:scientificName" },
    "scientificNameID":   { "@id": "dwc:scientificNameID" },
    "originalScientificName": { "@id": "dwc:scientificName" },
    "kingdom":  { "@id": "dwc:kingdom" },
    "phylum":   { "@id": "dwc:phylum" },
    "class":    { "@id": "dwc:class" },
    "order":    { "@id": "dwc:order" },
    "family":   { "@id": "dwc:family" },
    "genus":    { "@id": "dwc:genus" },
    "species":  { "@id": "dwc:scientificName" },
    "subphylum":   { "@id": "dwc:phylum" },
    "infraphylum": { "@id": "dwc:phylum" },
    "megaclass":   { "@id": "dwc:class" },
    "superclass":  { "@id": "dwc:class" },

    "kingdomid":    { "@id": "https://www.marinespecies.org/rest/AphiaRecordsByMatchNames?scientificnames=", "@type": "xsd:integer" },
    "phylumid":     { "@id": "https://w3id.org/iliad/property/wormsPhylumID", "@type": "xsd:integer" },
    "classid":      { "@id": "https://w3id.org/iliad/property/wormsClassID", "@type": "xsd:integer" },
    "orderid":      { "@id": "https://w3id.org/iliad/property/wormsOrderID", "@type": "xsd:integer" },
    "familyid":     { "@id": "https://w3id.org/iliad/property/wormsFamilyID", "@type": "xsd:integer" },
    "genusid":      { "@id": "https://w3id.org/iliad/property/wormsGenusID", "@type": "xsd:integer" },
    "speciesid":    { "@id": "https://w3id.org/iliad/property/wormsSpeciesID", "@type": "xsd:integer" },

    "decimalLatitude":              { "@id": "dwc:decimalLatitude", "@type": "xsd:double" },
    "decimalLongitude":             { "@id": "dwc:decimalLongitude", "@type": "xsd:double" },
    "coordinateUncertaintyInMeters":{ "@id": "dwc:coordinateUncertaintyInMeters", "@type": "xsd:double" },
    "country":       { "@id": "dwc:country" },
    "stateProvince": { "@id": "dwc:stateProvince" },
    "locality":      { "@id": "dwc:locality" },
    "modified":      { "@id": "dct:modified" },

    "id":         { "@id": "schema:identifier" },
    "dataset_id": { "@id": "dct:isPartOf", "@type": "@id" },
    "node_id":    { "@id": "schema:identifier" },
    "dropped":    { "@id": "https://w3id.org/iliad/property/obisDropped", "@type": "xsd:boolean" },
    "absence":    { "@id": "dwc:occurrenceStatus" },
    "flags":      { "@id": "https://w3id.org/iliad/property/obisFlags" },
    "category":   { "@id": "schema:category" },
    "unaccepted": { "@id": "https://w3id.org/iliad/property/wormsUnaccepted" },
    "marine":     { "@id": "https://w3id.org/iliad/property/wormsMarine", "@type": "xsd:boolean" },
    "brackish":   { "@id": "https://w3id.org/iliad/property/wormsBrackish", "@type": "xsd:boolean" },

    "aphiaID":     { "@id": "https://w3id.org/iliad/property/aphiaID", "@type": "xsd:integer" },
    "bathymetry":  { "@id": "http://vocab.nerc.ac.uk/collection/P01/current/MBANNV01/", "@type": "xsd:double" },
    "shoredistance":{ "@id": "http://vocab.nerc.ac.uk/collection/P01/current/DISDSHORE/", "@type": "xsd:double" },
    "sst":         { "@id": "http://vocab.nerc.ac.uk/collection/P01/current/TEMPPR01/", "@type": "xsd:double" },
    "sss":         { "@id": "http://vocab.nerc.ac.uk/collection/P01/current/PSALPR01/", "@type": "xsd:double" }
  }
}
