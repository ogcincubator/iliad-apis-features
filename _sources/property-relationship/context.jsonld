{
  "@context": {
    "prop-rel": "https://w3id.org/ogc/hosted/seadots/prop-rel/",
    "sosa": "http://www.w3.org/ns/sosa/",
    "prov": "http://www.w3.org/ns/prov#",
    "dct": "http://purl.org/dc/terms/",
    "qudt": "http://qudt.org/schema/qudt/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",
    "PropertyRelationship": "prop-rel:PropertyRelationship",
    "name": "schema:name",
    "fromProperty": { "@id": "prop-rel:fromProperty", "@type": "@id" },
    "toProperty": { "@id": "prop-rel:toProperty", "@type": "@id" },
    "weight": {
      "@id": "prop-rel:hasWeight",
      "@context": {
        "value": "qudt:numericValue",
        "unit": { "@id": "qudt:unit", "@type": "@id" }
      }
    },
    "explanation": "schema:explanation",
    "evidence": { "@id": "prov:wasDerivedFrom", "@type": "@id", "@container": "@set" },
    "model": {
      "@id": "prov:wasAttributedTo",
      "@context": {
        "id": "dct:identifier",
        "uri": "@id",
        "name": "schema:name"
      }
    },
    "experiment": {
      "@id": "prov:wasGeneratedBy",
      "@context": {
        "id": "dct:identifier",
        "uri": "@id",
        "start": { "@id": "prov:startedAtTime", "@type": "xsd:dateTime" },
        "end": { "@id": "prov:endedAtTime", "@type": "xsd:dateTime" }
      }
    }
  }
}
