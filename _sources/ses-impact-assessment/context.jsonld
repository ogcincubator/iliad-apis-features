{
  "@context": {
    "ses": "https://example.org/ses-core/",
    "oim": "https://w3id.org/iliad/oim/",
    "odd": "https://w3id.org/iliad/odd#",
    "prop-rel": "https://w3id.org/ogc/hosted/seadots/prop-rel/",
    "sosa": "http://www.w3.org/ns/sosa/",
    "prov": "http://www.w3.org/ns/prov#",
    "dct": "http://purl.org/dc/terms/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dqv": "http://www.w3.org/ns/dqv#",
    "schema": "https://schema.org/",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "geojson": "https://purl.org/geojson/vocab#",
    "geosparql": "http://www.opengis.net/ont/geosparql#",
    "qudt": "http://qudt.org/schema/qudt/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",
    "name": "rdfs:label",
    "description": "schema:description",
    "assessmentModel": { "@id": "prov:wasAttributedTo", "@type": "@id" },
    "informsAssessment": { "@id": "prov:influenced", "@type": "@id" },
    "buildingBlocks": { "@id": "dct:requires", "@container": "@set", "@type": "@id" },
    "proposedBuildingBlocks": { "@id": "schema:hasPart", "@container": "@set" },
    "block": { "@id": "schema:identifier", "@type": "@id" },
    "role": "schema:roleName",
    "implementsPath": "schema:usageInfo",
    "helpsBy": "schema:description",

    "extent": "dct:spatial",
    "bbox": { "@id": "geojson:bbox", "@container": "@list" },
    "geometry": "geosparql:hasGeometry",
    "indicators": { "@id": "ses:hasIndicator", "@container": "@set" },
    "indicator": { "@id": "sosa:observedProperty", "@type": "@id" },
    "qualitySpecification": "dqv:hasQualityMeasurement",
    "qualitySpecificationRef": { "@id": "dqv:hasQualityMeasurement", "@type": "@id" },
    "geospatialRequirements": "geosparql:hasGeometry",
    "oimVariableLayer": { "@id": "oim:hasVariableLayer", "@container": "@set" },
    "qualitySpecifications": { "@id": "dqv:hasQualityMeasurement", "@container": "@set" },

    "qualityRequirements": { "@id": "odd:qualityRequirement", "@container": "@set" },
    "relationshipExplanations": { "@id": "odd:relationshipExplanation", "@container": "@set" },

    "proposedInputData": { "@id": "prov:used", "@container": "@set" },
    "proposedOutputData": { "@id": "prov:generated", "@container": "@set" },
    "inventoryRow": "schema:position",
    "sourceInventory": { "@id": "prov:wasDerivedFrom", "@type": "@id" },
    "recommendedBuildingBlocks": { "@id": "dct:requires", "@container": "@set", "@type": "@id" },
    "assessment": "schema:reviewBody",
    "suitability": "schema:reviewRating",
    "limitations": "schema:conditionsOfAccess",
    "supportsIndicators": { "@id": "sosa:observedProperty", "@container": "@set", "@type": "@id" },
    "dataRole": "schema:additionalType",
    "experiments": { "@id": "ses:hasExperiment", "@container": "@set" },
    "inputProducts": { "@id": "prov:used", "@container": "@set", "@type": "@id" },
    "outputProducts": { "@id": "prov:generated", "@container": "@set", "@type": "@id" },

    "relationships": { "@id": "ses:hasRelationship", "@container": "@set" },
    "PropertyRelationship": "prop-rel:PropertyRelationship",
    "fromProperty": { "@id": "prop-rel:fromProperty", "@type": "@id" },
    "toProperty": { "@id": "prop-rel:toProperty", "@type": "@id" },
    "weight": { "@id": "prop-rel:hasWeight", "@context": { "value": "qudt:numericValue" } },
    "explanation": "schema:explanation",
    "evidence": { "@id": "prov:wasDerivedFrom", "@type": "@id" }
  }
}
