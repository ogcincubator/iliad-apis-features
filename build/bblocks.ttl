            prof:hasArtifact <https://opengeospatial.github.io/bblocks/registereditems/geo/features/featureCollection/shapes.shacl> ;
            prof:hasRole role:validation ],
        [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://ogc.sosa.properties.observation> ;
            prof:hasArtifact <https://opengeospatial.github.io/ogcapi-sosa/_sources/properties/observation/shapes.shacl> ;
            prof:hasRole role:validation ],
        [ dct:conformsTo shacl: ;
