<bblocks://ogc.hosted.iliad.api.features.coverage_information_model> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "OGC Coverage Implementation Schema" ;
    dct:abstract "Coverages represent homogeneous collections of values located in space/time, such as spatio-temporal sensor, image, simulation, and statistics data. Common examples include 1-D timeseries, 2-D imagery, 3-D x/y/t image timeseries and x/y/z geophysical voxel models, as well as 4-D x/y/z/t climate and ocean data. Generally, coverages encompass multi-dimen­sional regular and irregular grids, point clouds, and general meshes. This Coverage Implementation Schema (CIS) specifies the OGC coverage model by establishing a concrete, interoperable, conformance-testable coverage structure. It is based on the abstract concepts of OGC Abstract Topic 6 [1] (which is identical to ISO 19123) which spec­i­fies an abstract model which is not per se interoperable – in other words, many different and incompatible implementations of the abstract model are possible. CIS, on the other hand, is interoperable in the sense that coverages can be conformance tested, regardless of their data format encoding, down to the level of single pixels or voxels.Coverages can be encoded in any suitable format (such as GML, JSON, GeoTIFF, or Net­CDF) and can be partitioned, e.g., for a time-interleaved representation. Coverages are independent from service definitions and, therefore, can be accessed through a variety of OGC services types, such as the Web Coverage Service (WCS) Standard [8]. The coverage structure can serve a wide range of coverage application domains, thereby contributing to harmon­ization and interoperability between and across these domains."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2023-04-05T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/build/generateddocs/markdown/hosted/iliad/api/features/coverage_information_model/index.md> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/bblock/ogc.hosted.iliad.api.features.coverage_information_model> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/build/generateddocs/json-full/hosted/iliad/api/features/coverage_information_model/index.json> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-05-04"^^xsd:date ;
    dct:source <https://docs.ogc.org/is/09-146r8/09-146r8.html> ;
    skos:inScheme <https://ogcincubator.github.io/iliad-apis-features/> ;
    skos:prefLabel "OGC Coverage Implementation Schema" ;
    skos:topConceptOf <https://ogcincubator.github.io/iliad-apis-features/> ;
    dcat:keyword "Ogcdoc",
        "coverage",
        "datacube",
        "gridded data",
        "mesh",
        "point cloud",
        "sensor model",
        "timeseries" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://ogcincubator.github.io/iliad-apis-features/build/annotated/hosted/iliad/api/features/coverage_information_model/schema.json> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/yaml" ;
            prof:hasArtifact <https://ogcincubator.github.io/iliad-apis-features/build/annotated/hosted/iliad/api/features/coverage_information_model/schema.yaml> ;
            prof:hasRole role:schema ],
        [ dct:conformsTo <https://www.w3.org/TR/json-ld11/> ;
            dct:format "application/ld+json" ;
            prof:hasArtifact <https://ogcincubator.github.io/iliad-apis-features/build/annotated/hosted/iliad/api/features/coverage_information_model/context.jsonld> ;
            prof:hasRole role:mapping ] ;
    bblocks:hasSourceJsonLdContext <https://ogcincubator.github.io/iliad-apis-features/_sources/coverage_information_model/context.jsonld> ;
    bblocks:scope <http://www.opengis.net/def/bblocks/scope/unstable> ;
    bblocks:status <http://www.opengis.net/def/status/under-development> ;
    bblocks:validationPassed true .

<bblocks://ogc.hosted.iliad.api.features.dynamic-shoreline> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Dynamic Shoreline Feature" ;
    dct:abstract "Feature type for tide-dependent shoreline vectors, encoding shoreline type, water level at capture, tidal datum reference, sensor platform, and spatial/temporal uncertainty. Enables multi-temporal shoreline analysis and supports FMSDI Best Practice 3 (Mind the Gap) and Best Practice 1 (Unified Geospatial Reference). Derived from TCarta FMSDI demonstrator at Hurst Spit using Planet Labs NDWI and Capella SAR data."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-05-04T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/build/generateddocs/json-full/hosted/iliad/api/features/dynamic-shoreline/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/bblock/ogc.hosted.iliad.api.features.dynamic-shoreline> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://ogcincubator.github.io/iliad-apis-features/build/generateddocs/markdown/hosted/iliad/api/features/dynamic-shoreline/index.md> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-05-04"^^xsd:date ;
    dct:source <http://ogc.pages.ogc.org/FMSDI-2024-2/>,
        <http://ogc.pages.ogc.org/FMSDI-2024/>,
        <https://iho.int/en/iho-standards/standard-publications-and-s-32>,
        <https://iho.int/en/iho-standards/standard-publications-and-s-44> ;
    skos:inScheme <https://ogcincubator.github.io/iliad-apis-features/> ;
    skos:prefLabel "Dynamic Shoreline Feature" ;
    skos:topConceptOf <https://ogcincubator.github.io/iliad-apis-features/> ;
    dcat:keyword "coastal",
        "dynamic",
        "fmsdi",
        "iliad",
        "satellite",
        "shoreline",
        "tidal" ;
    prof:hasResource [ dct:conformsTo shacl: ;
            dct:format "text/turtle" ;
            rdfs:seeAlso <bblocks://ogc.hosted.iliad.api.features.oim-obs> ;
            prof:hasArtifact <https://ogcincubator.github.io/iliad-apis-features/_sources/oim-obs/rules.shacl> ;
            prof:hasRole role:validation ],
        [ dct:conformsTo <https://www.w3.org/TR/json-ld11/> ;
            dct:format "application/ld+json" ;
            prof:hasArtifact <https://ogcincubator.github.io/iliad-apis-features/build/annotated/hosted/iliad/api/features/dynamic-shoreline/context.jsonld> ;
