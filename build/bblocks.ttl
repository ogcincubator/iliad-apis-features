        "OIM master repository",
        "Ocean Information Model" .

<https://ogcincubator.github.io/iliad-apis-features/> a skos:ConceptScheme,
        dcat:Catalog,
        bblocks:BBlocksRegister ;
    rdfs:label "Building Blocks - ILIAD API Profiles" ;
    dct:abstract "(Under construction) - defines and demonstrates a reusable mechanism for specialisation of OGC APIs using the Oceans Information Model (OIM) for semantic interoperability."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:description """Each building block defines a profile of a data exchange schema based on OGC API responses, mapped to the OIM using JSON-LD contexts. Common patterns are factored into reusable foundations to simplify development and maximise interoperability of such profiles, in a way which is scalable across future application requirements. 

Thus, a pilot project to monitor Jellyfish swarms using Citizen Science will reuse common patterns for Citizen Science observations, which in turn we reuse a common pattern for observations, using an underlying component of the OIM - the OGC Observations model (SOSA ontology). 
"""^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:modified "2026-04-17T11:50:39.670329"^^xsd:dateTime ;
    owl:imports <https://ogcincubator.github.io/bblocks-sta/build/register.json>,
        <https://ogcincubator.github.io/bblocks-stac/build/register.json>,
        <https://ogcincubator.github.io/cross-domain-model/build/register.json>,
        <https://ogcincubator.github.io/geodcat-ogcapi-records/build/register.json>,
        <https://opengeospatial.github.io/bblocks/register.json>,
        <https://opengeospatial.github.io/ogcapi-sosa/build/register.json> ;
    skos:hasTopConcept <bblocks://ogc.hosted.iliad.api.features.coverageJSON>,
        <bblocks://ogc.hosted.iliad.api.features.coverageJSONFisheries>,
        <bblocks://ogc.hosted.iliad.api.features.coverage_information_model>,
        <bblocks://ogc.hosted.iliad.api.features.iliad-jellyfish-features>,
        <bblocks://ogc.hosted.iliad.api.features.iliad-jellyfish-ontology>,
        <bblocks://ogc.hosted.iliad.api.features.macroobservation>,
        <bblocks://ogc.hosted.iliad.api.features.marine-protected-area-emodnet>,
        <bblocks://ogc.hosted.iliad.api.features.oim>,
        <bblocks://ogc.hosted.iliad.api.features.oim-bio-tdwg>,
        <bblocks://ogc.hosted.iliad.api.features.oim-obs>,
        <bblocks://ogc.hosted.iliad.api.features.oim-obs-cs>,
        <bblocks://ogc.hosted.iliad.api.features.oim-sta-obs>,
        <bblocks://ogc.hosted.iliad.api.features.stac_multidim_data>,
        <bblocks://ogc.hosted.iliad.api.features.zarr_array_metadata>,
        <bblocks://ogc.hosted.iliad.api.features.zarr_attrs_metadata>,
        <bblocks://ogc.hosted.iliad.api.features.zarr_attrs_sdn> ;
    skos:prefLabel "Building Blocks - ILIAD API Profiles" ;
    prof:hasResource [ rdfs:label "This Building Blocks Register in JSON-LD format" ;
            dct:type "application/ld+json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/iliad-apis-features/build/bblocks.jsonld> ],
        [ rdfs:label "This Building Blocks Register in RDF Turtle format" ;
            dct:type "text/turtle" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/iliad-apis-features/build/bblocks.ttl> ],
        [ rdfs:label "This Building Blocks Register in JSON format" ;
            dct:type "application/json" ;
            ns1:relation <http://www.iana.org/assignments/relation/self> ;
            ns2:hasTarget <https://ogcincubator.github.io/iliad-apis-features/build/register.json> ] ;
