    {
      "itemIdentifier": "ogc.hosted.iliad.api.features.coverageJSON",
      "name": "OGC CoverageJSON",
      "abstract": "Based on JavaScript Object Notation (JSON), CoverageJSON is a format for publishing spatiotemporal data to the Web. The primary design goals are simplicity, machine and human readability and efficiency. While other use cases are possible, the primary CoverageJSON use case is enabling the development of interactive visual websites that display and manipulate environmental data within a web browser.",
      "status": "under-development",
      "dateTimeAddition": "2023-12-01T00:00:00Z",
      "itemClass": "schema",
      "register": "iliad-apis",
      "version": "0.1",
      "dateOfLastChange": "2026-05-04",
      "link": "https://github.com/opengeospatial/CoverageJSON",
      "sources": [
        {
          "title": "CoverageJSON context",
          "link": "https://docs.ogc.org/cs/21-069r2/21-069r2.html"
        },
        {
          "title": "Coverage Implementation Schema that CoverageJSON is based on",
          "link": "https://docs.ogc.org/is/09-146r8/09-146r8.html"
        }
      ],
      "maturity": "development",
      "scope": "unstable",
      "tags": [
        "Ogcdoc",
        "OGC document",
        "JSON",
        "JSON-LD",
        "CoverageJSON",
        "CovJSON",
        "coverage",
        "spatiotemporal",
        "linked-data"
      ],
