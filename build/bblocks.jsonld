      ],
      "scope": "dev",
      "shaclShapes": null,
      "schema": [
        {
          "prof:hasArtifact": "https://ogcincubator.github.io/iliad-apis-features/build/annotated/hosted/iliad/api/features/helcom_data_transformation/schema.yaml",
          "prof:hasRole": "role:schema",
